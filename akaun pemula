<!DOCTYPE html>
<html lang="ms">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>FHM Markets Invest - Demo</title>

<style>
*{margin:0;padding:0;box-sizing:border-box;font-family:Segoe UI,sans-serif}
body{background:#03140d;color:white;min-height:100vh}
.page{min-height:100vh;display:flex;justify-content:center;align-items:center;padding:20px}
.card{width:100%;max-width:430px;background:#061f15;border-radius:25px;padding:28px;box-shadow:0 20px 50px #000}
.logo{text-align:center;font-size:34px;font-weight:800;color:#f5c542;margin-bottom:5px}
.logo span{color:#22c55e}
.sub{text-align:center;color:#cbd5e1;margin-bottom:30px}
input{width:100%;padding:16px;margin-bottom:15px;border-radius:14px;border:1px solid #1f5f42;background:#03140d;color:white;font-size:16px}
button,.btn{width:100%;padding:16px;border:0;border-radius:14px;font-size:16px;font-weight:bold;color:white;text-align:center;text-decoration:none;display:block;cursor:pointer}
.loginBtn{background:#16a34a}
.telegram{background:#229ED9;margin-top:15px}
.error{color:#ff6b6b;text-align:center;margin-top:12px}
#dashboard{display:none;padding:20px}
.top{display:flex;justify-content:space-between;align-items:center;margin-bottom:25px}
.badge{background:#064e3b;padding:8px 14px;border-radius:20px;color:#86efac}
.balance{background:linear-gradient(135deg,#16a34a,#064e3b);padding:28px;border-radius:22px;margin-bottom:25px}
.balance p{font-size:15px;color:#dcfce7}
.balance h1{font-size:38px;margin-top:10px}
.menu{display:grid;grid-template-columns:1fr 1fr;gap:15px;margin-bottom:20px}
.box{padding:25px;border-radius:20px;text-align:center;background:#08291c;border:1px solid #22c55e}
.box.gold{background:#3b300b;border-color:#f5c542}
.box h3{margin-top:10px}
.safe{background:#08291c;padding:20px;border-radius:18px;margin-top:20px;color:#d1fae5}
.logout{background:#dc2626;margin-top:20px}
.note{text-align:center;color:#94a3b8;font-size:12px;margin-top:20px}
</style>
</head>

<body>

<div id="loginPage" class="page">
  <div class="card">
    <div class="logo">FHM <span>MARKETS</span></div>
    <div class="sub">Sila log masuk ke akaun e-Wallet demo anda</div>

    <input type="text" id="user" placeholder="ID Pengguna">
    <input type="password" id="pass" placeholder="Kata Laluan">

    <button class="loginBtn" onclick="login()">LOG MASUK</button>

    <a class="btn telegram" href="https://t.me/USERNAME_TELEGRAM" target="_blank">
      Hubungi Admin Telegram
    </a>

    <div id="error" class="error"></div>
    <div class="note">Paparan demo sahaja, bukan sistem kewangan sebenar.</div>
  </div>
</div>

<div id="dashboard">
  <div class="top">
    <h2>FHM Markets Invest</h2>
    <div class="badge">Akaun Aktif</div>
  </div>

  <h3>Selamat Datang, FHM001</h3>

  <div class="balance">
    <p>JUMLAH BAKI</p>
    <h1>RM 380,000.00</h1>
    <p>e-Wallet FHM</p>
  </div>

  <div class="menu">
    <div class="box">
      <div style="font-size:40px">💵</div>
      <h3>DEPOSIT</h3>
      <p>Tambah Baki</p>
    </div>

    <div class="box gold">
      <div style="font-size:40px">💸</div>
      <h3>WITHDRAW</h3>
      <p>Pengeluaran</p>
    </div>
  </div>

  <a class="btn telegram" href="https://t.me/USERNAME_TELEGRAM" target="_blank">
    💬 Hubungi Admin Telegram
  </a>

  <div class="safe">
    <h3>Keselamatan Akaun</h3>
    <p>Jangan kongsi ID pengguna atau kata laluan anda dengan sesiapa.</p>
  </div>

  <button class="logout" onclick="logout()">LOG KELUAR</button>
</div>

<script>
function login(){
  let user = document.getElementById("user").value;
  let pass = document.getElementById("pass").value;

  if(user === "fhm001" && pass === "123456"){
    document.getElementById("loginPage").style.display = "none";
    document.getElementById("dashboard").style.display = "block";
  }else{
    document.getElementById("error").innerHTML =
    "ID Pengguna atau Kata Laluan tidak sah.";
  }
}

function logout(){
  document.getElementById("dashboard").style.display = "none";
  document.getElementById("loginPage").style.display = "flex";
}
</script>

</body>
</html>
